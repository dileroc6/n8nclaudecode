# =====================================================================
# Savia Wear — Sales Agent
# Plantilla de variables de entorno (sin valores reales)
#
# Copiar a .env y completar. NO commitear el .env real.
# Estas variables se cargan en n8n → Settings → Environment Variables.
# =====================================================================

# ---------- Evolution API (canal único — clientes + admin) ----------
EVOLUTION_API_URL=https://evolution.srv1398596.hstgr.cloud
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_SAVIA=savia
SAVIA_WHATSAPP_BUSINESS=57                      # número de WhatsApp Business de Savia (E.164 sin +)
SAVIA_ADMIN_PHONES=                             # E.164 con + del/los admin(s), separados por coma

# ---------- WooCommerce REST API ----------
# WP Admin → WooCommerce → Settings → Advanced → REST API → Add key
# Scope: Read/Write (lectura de productos Y creación de pedidos)
WOO_BASE_URL=https://savia-wear.com
WOO_CONSUMER_KEY=                               # ck_...
WOO_CONSUMER_SECRET=                            # cs_...

# Slug del método de pago Mercado Pago en WooCommerce
# Verificar en WP Admin → Pedidos → abrir un pedido pagado con MP → campo "Método de pago"
# Suele ser 'mercadopago' o 'woo-mercado-pago' — confirmar con el admin del sitio
WOO_PAYMENT_METHOD=mercadopago

# Secret del webhook de WooCommerce — Order updated
# WP Admin → WooCommerce → Settings → Advanced → Webhooks → Secret
WC_WEBHOOK_SECRET=

# ---------- PostgreSQL ----------
PG_HOST=localhost
PG_PORT=5432
PG_DB=leadai
PG_SCHEMA=savia
PG_USER=leadai_user
PG_PASSWORD=

# ---------- OpenAI API ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---------- Lógica de negocio ----------
SAVIA_TARIFA_PREMIUM_THRESHOLD=50               # Contactos únicos/día para disparar alerta
SAVIA_PEDIDO_EXPIRA_HORAS=48                    # Tiempo de vida del payment link
