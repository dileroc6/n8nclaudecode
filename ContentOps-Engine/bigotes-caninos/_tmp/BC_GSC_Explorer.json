      "parameters": {
        "jsCode": "const queriesNode = $('GSC: Top 1000 Queries (16m)').first().json;\nconst pagesNode = $('GSC: Top 200 Pages (16m)').first().json;\n\nconst queries = queriesNode.rows || [];\nconst pages = pagesNode.rows || [];\n\nconst totals = (rows) => rows.reduce((acc, r) => {\n  acc.clicks += r.clicks || 0;\n  acc.impressions += r.impressions || 0;\n  return acc;\n}, { clicks: 0, impressions: 0 });\n\nreturn [{\n  json: {\n    site: 'sc-domain:bigotescaninos.com',\n    period: { start: '2025-01-06', end: '2026-05-06', months: 16 },\n    queries_count: queries.length,\n    pages_count: pages.length,\n    queries_totals: totals(queries),\n    pages_totals: totals(pages),\n    queries: queries.map(r => ({\n      query: r.keys[0],\n      clicks: r.clicks,\n      impressions: r.impressions,\n      ctr: Math.round((r.ctr || 0) * 10000) / 10000,\n      position: Math.round((r.position || 0) * 100) / 100\n    })),\n    pages: pages.map(r => ({\n      page: r.keys[0],\n      clicks: r.clicks,\n      impressions: r.impressions,\n      ctr: Math.round((r.ctr || 0) * 10000) / 10000,\n      position: Math.round((r.position || 0) * 100) / 100\n    }))\n  }\n}];"
