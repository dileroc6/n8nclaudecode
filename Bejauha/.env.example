# =====================================================================
# Bejauha — Yoga & Bienestar · Agentes WhatsApp IA
# Plantilla de variables de entorno (SIN valores reales)
#
# Copiar a .env y completar. NUNCA commitear el .env real.
# Estas variables se cargan en n8n → Settings → Environment Variables.
# =====================================================================

# ---------- Evolution API (canal WhatsApp — outbound + inbound) ----------
# Credenciales compartidas (mismas de Savia): URL + KEY viven en las env
# vars de n8n, no en este repo. Instancia de arranque: dev-router (prueba).
# Para go-live cambiar a la instancia con el número oficial de Bejauha.
EVOLUTION_API_URL=https://evolution.srv1398596.hstgr.cloud
EVOLUTION_API_KEY=
# Dos líneas separadas por riesgo de baneo:
EVOLUTION_INSTANCE_OUTBOUND=dev-router          # LÍNEA DEDICADA — solo Agente 1 (outbound a los 1.300)
EVOLUTION_INSTANCE_PRINCIPAL=dev-router         # LÍNEA PRINCIPAL Bejauha — Agente 2 (admin) + Agente 3 (inbound)
BEJAUHA_WHATSAPP_BUSINESS=573122011349          # número principal Bejauha (E.164 sin +) · recibe leads calientes
BEJAUHA_ASESOR_PHONES=                          # E.164 con + de admins (Cami/Amanda/Isa) para handoff y control de clases

# ---------- PostgreSQL (instancia compartida — esquema independiente) ----------
# Conexión real: contenedor Docker `evolution_postgres` (postgres:15).
# En la red de Docker, n8n se conecta usando host = evolution_postgres.
# DB `leadai` aloja los esquemas por cliente (savia, zoe, luxe_smile, bejauha),
# todos propiedad de leadai_user.
PG_HOST=evolution_postgres                       # nombre del contenedor en la red Docker
PG_PORT=5432
PG_DB=leadai
PG_SCHEMA=bejauha                               # RESTRICCIÓN: esquema propio, nunca public
PG_USER=leadai_user
PG_PASSWORD=

# ---------- LLM (clasificación + conversación) ----------
# Mismas credenciales de Savia (viven en env vars de n8n).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------- Lógica de negocio ----------
BEJAUHA_LOTE_DIARIO=20                            # leads outbound/día (objetivo en régimen)
BEJAUHA_WARMUP_DIARIO=5                           # arranque del warm-up (sem 1: 5, sem 2: 10, luego 20)
BEJAUHA_ENVIO_INTERVALO_MIN=2                     # minutos mínimos entre envíos (humanizar)
BEJAUHA_ENVIO_INTERVALO_MAX=5                     # minutos máximos entre envíos
BEJAUHA_HORARIO_ENVIO=09:00-19:00                # ventana horaria de envío (America/Bogota)
BEJAUHA_VENTANA_RESPUESTA_HORAS=72               # horas de espera antes de marcar sin_respuesta
BEJAUHA_TIMEZONE=America/Bogota                  # CRÍTICO: el container n8n corre en Europe/Berlin;
                                                 # todo workflow con cron debe fijar settings.timezone
