# ============================================================================
# Zoe Tantric SPA — Variables de entorno
# Copia este archivo a .env y reemplaza los valores marcados PENDIENTE.
# .env está gitignored — NUNCA commitearlo.
# ============================================================================

# ----------------------------------------------------------------------------
# n8n (compartida con todos los clientes del VPS)
# ----------------------------------------------------------------------------
N8N_API_URL=https://n8n.srv1398596.hstgr.cloud/api/v1
N8N_API_KEY=PENDIENTE_COPIAR_DE_LUXESMILE

# ----------------------------------------------------------------------------
# Evolution API (servidor compartido, instancia dedicada para Zoe)
# ----------------------------------------------------------------------------
EVOLUTION_API_URL=https://evolution.srv1398596.hstgr.cloud
EVOLUTION_API_KEY=PENDIENTE_COPIAR_DE_LUXESMILE
# Crear esta instancia en Evolution antes del primer deploy:
EVOLUTION_INSTANCE_ZOE=zoe

# ----------------------------------------------------------------------------
# PostgreSQL (instancia compartida del VPS, schema dedicado `zoe`)
# ----------------------------------------------------------------------------
PG_HOST=postgres
PG_PORT=5432
PG_DB=leadai
PG_SCHEMA=zoe
PG_USER=leadai_user
PG_PASSWORD=PENDIENTE_COPIAR_DE_LUXESMILE

# Usuario solo-lectura para Metabase (crear con sql/04_metabase_user.sql cuando llegue el momento)
PG_READONLY_USER=zoe_readonly
PG_READONLY_PASSWORD=PENDIENTE_GENERAR

# ----------------------------------------------------------------------------
# OpenAI (GPT-4o-mini para el agente conversacional)
# La credencial vive dentro de n8n; los workflows la referencian por ID.
# ----------------------------------------------------------------------------
OPENAI_CREDENTIAL_ID_N8N=PENDIENTE_ID_DE_LA_CREDENCIAL_EN_N8N
OPENAI_MODEL=gpt-4o-mini
# Solo si se necesita fuera de n8n (scripts locales). Opcional.
# OPENAI_API_KEY=

# ----------------------------------------------------------------------------
# Admin (canal de control via WhatsApp)
# ----------------------------------------------------------------------------
# Formato MSISDN sin '+' ni espacios. Múltiples admins separados por coma.
ADMIN_PHONES=PENDIENTE_NUMERO_ADMIN

# ----------------------------------------------------------------------------
# Configuración de negocio
# ----------------------------------------------------------------------------
TZ=America/Bogota
OTP_VENTANA_MINUTOS=60
OTP_DELAY_DESPUES_INICIO_MIN=30
LIMITE_REPROGRAMACIONES=3
RECORDATORIO_HORAS_ANTES=24

# ----------------------------------------------------------------------------
# Metabase (dashboard admin — solo lectura)
# ----------------------------------------------------------------------------
METABASE_URL=https://metabase.srv1398596.hstgr.cloud
METABASE_DB_PASSWORD=PENDIENTE_GENERAR
