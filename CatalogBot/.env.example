# =============================================================================
# CatalogBot — Variables de entorno
# Copiar a .env y completar con valores reales. NUNCA commitear .env
# =============================================================================

# -----------------------------------------------------------------------------
# n8n
# -----------------------------------------------------------------------------
# URL base de la instancia n8n (sin barra final)
N8N_URL=https://n8n.tudominio.com
# API key de n8n (Settings → API → Create API Key)
N8N_API_KEY=

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Host del servidor PostgreSQL (en VPS Hostinger: localhost o 127.0.0.1)
PGHOST=localhost
# Puerto PostgreSQL (default 5432)
PGPORT=5432
# Nombre de la base de datos del sistema
PGDATABASE=catalogbot
# Usuario PostgreSQL con permisos de CREATE SCHEMA y escritura
PGUSER=catalogbot_user
# Contraseña del usuario PostgreSQL
PGPASSWORD=
# URL de conexión completa (alternativa a los campos anteriores)
DATABASE_URL=postgresql://catalogbot_user:PASSWORD@localhost:5432/catalogbot

# -----------------------------------------------------------------------------
# Evolution API v2
# -----------------------------------------------------------------------------
# URL base de Evolution API (sin barra final)
EVOLUTION_API_URL=https://evolution.tudominio.com
# API key global de Evolution API (configurada en el archivo de entorno de Evolution)
EVOLUTION_API_KEY=

# -----------------------------------------------------------------------------
# Anthropic (Claude API)
# -----------------------------------------------------------------------------
# API key de Anthropic (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=
# Modelo a usar (no cambiar sin actualizar WF-B)
ANTHROPIC_MODEL=claude-sonnet-4-5

# -----------------------------------------------------------------------------
# Cloudinary
# -----------------------------------------------------------------------------
# Cloud name de la cuenta Cloudinary (Settings → Account)
CLOUDINARY_CLOUD_NAME=
# API key de Cloudinary (Settings → API Keys)
CLOUDINARY_API_KEY=
# API secret de Cloudinary (Settings → API Keys)
CLOUDINARY_API_SECRET=
# Preset de upload sin firma (Settings → Upload → Upload presets)
CLOUDINARY_UPLOAD_PRESET=catalogbot_unsigned

# -----------------------------------------------------------------------------
# Sistema
# -----------------------------------------------------------------------------
# Entorno de ejecución: development | production
NODE_ENV=development
# Secreto para cifrar webhook_secret en PostgreSQL con pgcrypto
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PGCRYPTO_SECRET=
# Número de WhatsApp del administrador del sistema para alertas críticas
# Formato: código de país + número sin + ni espacios (ej: 573001234567)
ADMIN_WHATSAPP=
