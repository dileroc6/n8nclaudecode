 datos del mensaje').item.json.pushName || '' }}","type":"string"},{"id":"a4","name":"language","value":"={{ $json.language || 'en' }}","type":"string"},{"id":"a5","name":"estado","value":"={{ $json.estado || 'captacion' }}","type":"string"},{"id":"a6","name":"phone","value":"={{ $('Extraer datos del mensaje').item.json.phone }}","type":"string"},{"id":"a7","name":"remoteJid","value":"={{ $('Extraer datos del mensaje').item.json.remoteJid }}","type":"string"},{"id":"a8","name":"messageText","value":"={{ $('Extraer datos del mensaje').item.json.messageText }}","type":"string"},{"id":"a9","name":"hasMedia","value":"={{ $('Extraer datos del mensaje').item.json.hasMedia }}","type":"boolean"},{"id":"a10","name":"mediaUrl","value":"={{ $('Extraer datos del mensaje').item.json.mediaUrl }}","type":"string"},{"id":"a11","name":"isNewLead","value":false,"type":"boolean"}]},"options":{}}},{"id":"n10","name":"Preparar inserción nuevo lead","type":"n8n-nodes-base.code","typeVersion":2,"position":[1520,500],"parameters":{"jsCode":"const extract = $('Extraer datos del mensaje').item.json;\nconst phone = extract.phone;\nconst pushName = (extract.pushName || '').replace(/'/g, \"''\").substring(0, 120);\n\nreturn [{\n  json: {\n    phone,\n    safeName: pushName,\n    language: 'en',\n    remoteJid: extract.remoteJid,\n    messageText: extract.messageText,\n    hasMedia: extract.hasMedia,\n    mediaUrl: extract.mediaUrl\n  }\n}];"}},{"id":"n11","name":"Crear lead en DB","type":"n8n-nodes-base.postgres","typeVersion":2.5,"position":[1740,500],"parameters":{"operation":"executeQuery","query":"WITH ins AS (\n  INSERT INTO luxe_smile.leads (sku, phone, name, language, estado)\n  VALUES ('TEMP', $1, $2, $3, 'captacion')\n  RETURNING id, phone, name, language, estado\n),\nupd AS (\n  UPDATE luxe_smile.leads\n  SET sku = LPAD(ins.id::TEXT, 4, '0')\n  FROM ins\n  WHERE luxe_smile.leads.id = ins.id\n  RETURNING luxe_smile.leads.id, luxe_smile.leads.sku,\n            luxe_smile.leads.phone, luxe_smile.leads.name,\n            luxe_smile.leads.language, luxe_smile.leads.estado\n)\nSELECT * FROM upd","options":{"queryReplacement":"={{ [$json.phone, $json.safeName, $json.language].join(',') }}"}},"credentials":{"postgres":{"id":"vzzTNppBFKg9XCiK","name":"PostgreSQL — LeadAI"}},"notes":"SKU generado automáticamente como LPAD(id, 4, '0'). Para producción con alto volumen considera una secuencia PostgreSQL dedicada."},{"id":"n12","name":"Preparar datos nuevo lead","type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1960,500],"parameters":{"mode":"manual","assignments":{"assignments":[{"id":"a1","name":"leadId","value":"={{ $json.id }}","type":"number"},{"id":"a2","name":"sku","value":"={{ $json.sku }}","type":"string"},{"id":"a3","name":"leadName","value":"={{ $json.name || '' }}","type":"string"},{"id":"a4","name":"language","value":"={{ $json.language || 'en' }}","type":"string"},{"id":"a5","name":"estado","value":"captacion","type":"string"},{"id":"a6","name":"phone","value":"={{ $json.phone }}","type":"string"},{"id":"a7","name":"remoteJid","value":"={{ $('Preparar inserción nuevo lead').item.json.remoteJid }}","type":"string"},{"id":"a8","name":"messageText","value":"={{ $('Preparar inserción nuevo lead').item.json.messageText }}","type":"string"},{"id":"a9","name":"hasMedia","value":"={{ $('Preparar inserción nuevo lead').item.json.hasMedia }}","type":"boolean"},{"id":"a10","name":"mediaUrl","value":"={{ $('Preparar inserción nuevo lead').item.json.mediaUrl }}","type":"string"},{"id":"a11","name":"isNewLead","value":true,"type":"boolean"}]},"options":{}}},{"id":"n13","name":"Cargar historial conversación","type":"n8n-nodes-base.postgres","typeVersion":2.5,"position":[2180,400],"parameters":{"operation":"executeQuery","query":"SELECT rol, contenido FROM luxe_smile.mensajes WHERE lead_sku = $1 ORDER BY created_at ASC","options":{"queryReplacement":"={{ $json.sku }}"}},"credentials":{"postgres":{"id":"vzzTNppBFKg9XCiK","name":"PostgreSQL — LeadAI"}}},{"id":"n14","name":"Preparar contexto para agente","type":"n8n-nodes-base.code","typeVersion":2,"position":[2400,400],"parameters":{"jsCode":"// Recuperar datos del lead (viene de n09 o n12 según la rama)\nconst prevNodes = ['Preparar datos lead existente', 'Preparar datos nuevo lead'];\nlet leadData = null;\nfor (const nodeName of prevNodes) {\n  try {\n    leadData = $(nodeName).item.json;\n    if (leadData.sku) break;\n  } catch(e) { /* node no ejecutado en esta rama */ }\n}\n\n// Historial de conversación\nconst historialItems = $input.all();\nconst historial = historialItems\n  .filter(h => h.json.rol && h.json.contenido)\n  .map(h => `${h.json.rol === 'user' ? 'Lead' : 'Bot'}: ${h.json.contenido}`)\n  .join('\\n');\n\nconst prompt = `You are Luna, the WhatsApp assistant for Luxe Smile, a dental tourism clinic specializing in porcelain veneers for international patients.\n\nABSOLUTE RULES:\n1. Always respond in the SAME language as the lead first message. Never switch languages.\n2. Strategy: BENEFITS FIRST — never mention price until lead shows clear interest.\n3. Your response MUST be valid JSON only — no text outside the JSON:\n{\"message\":\"your message here\",\"newState\":\"captacion|fotos_solicitadas|fotos_enviadas\",\"sendImage\":false,\"imageCaption\":\"\"}\n\nLUXE SMILE PACKAGE (benefits, NOT price until interest confirmed):\n- 10 upper + 10 lower porcelain veneers — complete smile transformation\n- Gum contouring + deep cleaning included\n- 5-night hotel stay included\n- Airport-clinic-hotel transfers included\n\nPROCESS (only after clear interest): Photos → specialist evaluation (3h) → personalized quote → $500 USD deposit\n\nCURRENT LEAD STATE: ${leadData.estado}\nLEAD NAME: ${leadData.leadName || 'the lead'}\nRECENT CONVERSATION:\n${historial || '(no prior conversation)'}\n\nCURRENT MESSAGE: ${leadData.messageText}\nHAS MEDIA: ${leadData.hasMedia}\n\nBEHAVIOR BY STATE:\ncaptacion: Greet warmly. Present package benefits. If clear interest → explain process, ask for smile photos, sendImage=true, newState=fotos_solicitadas. No interest yet → keep engaging, newState=captacion.\nfotos_solicitadas:\n- If hasMedia=true → confirm receipt warmly, say specialists will review in up to 3h, newState=fotos_enviadas.\n- If lead confirms a future time (\"next week\", \"tomorrow\", \"soon\", \"later\", or similar) → acknowledge warmly, say you will be waiting, wish them a great day. Say goodbye. Do NOT repeat the photo guide. Keep newState=fotos_solicitadas.\n- If lead sends a closing or courtesy message (\"thanks\", \"ok\", \"got it\", \"perfect\", \"bye\", or similar) → brief warm farewell. Do NOT remind about photos. Keep newState=fotos_solicitadas.\n- If lead sends text with no indication of when they will send photos → remind warmly to send their smile photos. Keep newState=fotos_solicitadas.\nfotos_enviadas: Say team is reviewing, will respond soon. Keep newState=fotos_enviadas.\nother states: Acknowledge politely, keep current state.\n\nTONE: Warm, professional, enthusiastic about transformations. Concise WhatsApp messages.`;\n\nreturn [{\n  json: {\n    ...leadData,\n    historialFormateado: historial,\n    systemPrompt: prompt,\n    userMessage: leadData.messageText || '(media message)'\n  }\n}];"}},{"id":"n15","name":"Modelo Claude","type":"@n8n/n8n-nodes-langchain.lmChatAnthropic","typeVersion":1.3,"position":[2620,560],"parameters":{"model":"={{ $env['CLAUDE_MODEL'] || 'claude-opus-4-5' }}","options":{"maxTokens":1024,"temperature":0.3}},"credentials":{"anthropicApi":{"id":"6a9Pt3vI39KsmCa0","name":"Anthropic API — LeadAI"}}},{"id":"n16","name":"AI Agent — Bot Luxe Smile","type":"@n8n/n8n-nodes-langchain.agent","typeVersion":1.7,"position":[2620,400],"parameters":{"agent":"conversationalAgent","promptType":"define","text":"={{ $json.userMessage }}","options":{"systemMessage":"={{ $json.systemPrompt }}"}}},{"id":"n17","name":"Parsear respuesta del agente","type":"n8n-nodes-base.code","typeVersion":2,"position":[2840,400],"parameters":{"jsCode":"const output = $json.output || $json.text || $json.response || '';\nconst ctx = $('Preparar contexto para agente').item.json;\n\nlet parsed;\ntry {\n  // Extraer JSON aunque haya texto alrededor\n  const match = output.match(/\\{[\\s\\S]*\\}/);\n  parsed = JSON.parse(match ? match[0] : output);\n} catch(e) {\n  // Fallback si el agente no devolvió JSON válido\n  parsed = {\n    message: output.substring(0, 1000),\n    newState: ctx.estado,\n    sendImage: false,\n    imageCaption: ''\n  };\n}\n\nreturn [{\n  json: {\n    sku: ctx.sku,\n    phone: ctx.phone,\n    remoteJid: ctx.remoteJid,\n    estadoAnterior: ctx.estado,\n    messageText: ctx.messageText,\n    agentMessage: parsed.message || '',\n    newState: parsed.newState || ctx.estado,\n    sendImage: parsed.sendImage || false,\n    imageCaption: parsed.imageCaption || '',\n    language: ctx.language || 'en'\n  }\n}];"}},{"id":"n18","name":"¿Enviar imagen guía?","type":"n8n-nodes-base.if","typeVersion":2,"position":[3060,400],"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict"},"conditions":[{"id":"c1","leftValue":"={{ $json.sendImage }}","rightValue":true,"operator":{"type":"boolean","operation":"equal"}}],"combinator":"and"},"options":{}}},{"id":"n19","name":"Enviar imagen guía fotográfica","type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3280,300],"parameters":{"method":"POST","url":"={{ $env['EVOLUTION_API_URL'] }}/message/sendMedia/{{ $env['EVOLUTION_INSTANCE_LUXE'] }}","authentication":"genericCredentialType","genericAuthType":"httpHeaderAuth","sendHeaders":true,"headerParameters":{"parameters":[{"name":"Content-Type","value":"application/json"}]},"sendBody":true,"bodyParameters":{"parameters":[{"name":"number","value":"={{ $json.phone }}"},{"name":"mediatype","value":"image"},{"name":"media","value":"={{ $env['LUXE_PHOTO_GUIDE_URL'] }}"},{"name":"caption","value":"={{ $json.imageCaption }}"}]},"options":{}},"credentials":{"httpHeaderAuth":{"id":"QT0zn550ysJh8VpI","name":"Evolution API — Luxe Smile"}}},{"id":"n20","name":"Enviar mensaje texto al lead","type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[3500,400],"parameters":{"method":"POST","url":"={{ $env['EVOLUTION_API_URL'] }}/message/sendText/{{ $env['EVOLUTION_INSTANCE_LUXE'] }}","authentication":"genericCredentialType","genericAuthType":"httpHeaderAuth","sendHeaders":true,"headerParameters":{"parameters":[{"name":"Content-Type","value":"application/json"}]},"sendBody":true,"bodyParameters":{"parameters":[{"name":"number","value":"={{ $json.phone }}"},{"name":"text","value":"={{ $json.agentMessage }}"}]},"options":{}},"credentials":{"httpHeaderAuth":{"id":"QT0zn550ysJh8VpI","name":"Evolution API — Luxe Smile"}}},{"id":"n21","name":"Actualizar estado del lead","type":"n8n-nodes-base.postgres","typeVersion":2.5,"position":[3720,400],"parameters":{"operation":"executeQuery","query":"UPDATE luxe_smile.leads SET estado = $1, name = COALESCE(NULLIF(name,''), $2) WHERE sku = $3","options":{"queryReplacement":"={{ [$json.newState, $json.phone, $json.sku].join(',') }}"}},"credentials":{"postgres":{"id":"vzzTNppBFKg9XCiK","name":"PostgreSQL — LeadAI"}},"notes":"Actualiza estado y preserva el nombre si ya estaba guardado"},{"id":"n22","name":"Registrar mensajes en DB","type":"n8n-nodes-base.code","typeVersion":2,"position":[3940,400],"parameters":{"jsCode":"// Recuperar contexto del paso de parseo\nconst ctx = $('Parsear respuesta del agente').item.json;\n\n// Dos filas: mensaje entrante del lead + respuesta del bot\nreturn [\n  {\n    json: {\n      lead_sku: ctx.sku,\n      rol: 'user',\n      contenido: ctx.messageText || '',\n      media_url: null\n    }\n  },\n  {\n    json: {\n      lead_sku: ctx.sku,\n      rol: 'assistant',\n      contenido: ctx.agentMessage || '',\n      media_url: null\n    }\n  }\n];"}},{"id":"n23","name":"Guardar mensajes en DB","type":"n8n-nodes-base.postgres","typeVersion":2.5,"pos