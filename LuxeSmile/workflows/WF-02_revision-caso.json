leadSku }}","type":"string"},{"id":"a5","name":"leadName","value":"={{ $('Preparar contexto revisión').item.json.leadName }}","type":"string"}]},"options":{}}},{"id":"w2n16","name":"Preparar mensaje FALTA INFO","type":"n8n-nodes-base.code","typeVersion":2,"position":[2180,540],"parameters":{"jsCode":"const ctx = $('Preparar contexto revisión').item.json;\nconst isEs = ctx.language === 'es';\nconst msg = isEs\n  ? `Hola ${ctx.leadName || 'ahí'} 😊 Nuestro equipo revisó tu caso y para darte una evaluación más precisa, ¿podrías enviarnos también: ${ctx.detalle || 'fotos adicionales de tu sonrisa'}? ¡Queremos asegurarnos de darte la mejor recomendación!`\n  : `Hi ${ctx.leadName || 'there'} 😊 Our team reviewed your case! To give you a more accurate evaluation, could you also send us: ${ctx.detalle || 'additional smile photos'}? We want to make sure we give you the best recommendation possible!`;\nreturn [{ json: { mensajeParaLead: msg, nuevoEstado: 'revision_pendiente', leadPhone: ctx.leadPhone, leadSku: ctx.leadSku, leadName: ctx.leadName } }];"}},{"id":"w2n17","name":"Preparar mensaje NO VIABLE","type":"n8n-nodes-base.code","typeVersion":2,"position":[2180,660],"parameters":{"jsCode":"const ctx = $('Preparar contexto revisión').item.json;\nconst isEs = ctx.language === 'es';\nconst msg = isEs\n  ? `Hola ${ctx.leadName || 'ahí'}, muchas gracias por confiar en Luxe Smile 🙏 Después de revisar tu caso con nuestros especialistas, en este momento no somos la clínica más adecuada para tu situación específica. Queremos ser honestos contigo porque lo mereces. Si en el futuro tu situación cambia, estaremos aquí.`\n  : `Hi ${ctx.leadName || 'there'}, thank you so much for trusting Luxe Smile 🙏 After reviewing your case with our specialists, we feel we may not be the best fit for your specific needs at this time. We want to be honest with you — you deserve that. If things change in the future, we'll be here for you.`;\nreturn [{ json: { mensajeParaLead: msg, nuevoEstado: 'no_viable', leadPhone: ctx.leadPhone, leadSku: ctx.leadSku, leadName: ctx.leadName } }];"}},{"id":"w2n18","name":"Enviar mensaje al lead","type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[2620,400],"parameters":{"method":"POST","url":"={{ $env['EVOLUTION_API_URL'] }}/message/sendText/{{ $env['EVOLUTION_INSTANCE_LUXE'] }}","authentication":"genericCredentialType","genericAuthType":"httpHeaderAuth","sendHeaders":true,"headerParameters":{"parameters":[{"name":"Content-Type","value":"application/json"}]},"sendBody":true,"bodyParameters":{"parameters":[{"name":"number","value":"={{ $json.leadPhone }}"},{"name":"text","value":"={{ $json.mensajeParaLead }}"}]},"options":{}},"credentials":{"httpHeaderAuth":{"id":"QT0zn550ysJh8VpI","name":"Evolution API — Luxe Smile"}}},{"id":"w2n19","name":"Actualizar estado lead en DB","type":"n8n-nodes-base.postgres","typeVersion":2.5,"position":[2840,400],"parameters":{"operation":"executeQuery","query":"UPDATE luxe_smile.leads SET estado = $1 WHERE sku = $2","options":{"queryReplacement":"={{ [$json.nuevoEstado, $json.leadSku].join(',') }}"}},"credentials":{"postgres":{"id":"vzzTNppBFKg9XCiK","name":"PostgreSQL — LeadAI"}}},{"id":"w2n20","name":"Guardar mensaje saliente en DB","type":"n8n-nodes-base.postgres","typeVersion":2.5,"position":[3060,400],"parameters":{"operation":"executeQuery","query":"INSERT INTO luxe_smile.mensajes (lead_sku, rol, contenido) VALUES ($1, 'assistant', $2)","options":{"queryReplacement":"={{ [$json.leadSku, $json.mensajeParaLead].join(',') }}"}},"credentials":{"postgres":{"id":"vzzTNppBFKg9XCiK","name":"PostgreSQL — LeadAI"}}},{"id":"w2n21","name":"Error Trigger","type":"n8n-nodes-base.errorTrigger","typeVersion":1,"position":[200,700],"parameters":{}},{"id":"w2n22","name":"Notificar error al admin","type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[420,700],"parameters":{"method":"POST","url":"={{ $env['EVOLUTION_API_URL'] }}/message/sendText/{{ $env['EVOLUTION_INSTANCE_LUXE'] }}","auth