{"updatedAt":"2026-04-18T17:23:29.179Z","createdAt":"2026-04-18T17:23:29.179Z","id":"jeFR0qJOte0JuzTf","name":"Luxe Smile — Revisión de Caso (Human Loop)","description":null,"active":false,"isArchived":false,"nodes":[{"id":"w2n01","name":"Webhook Grupo Revisión","type":"n8n-nodes-base.webhook","typeVersion":2,"position":[200,400],"parameters":{"path":"luxe-smile-group-revision","method":"POST","responseMode":"onReceived","responseData":"allEntries","options":{}}},{"id":"w2n02","name":"Extraer datos del mensaje grupo","type":"n8n-nodes-base.set","typeVersion":3.4,"position":[420,400],"parameters":{"mode":"manual","assignments":{"assignments":[{"id":"a1","name":"remoteJid","value":"={{ ($json.body?.data?.key?.remoteJid || '') }}","type":"string"},{"id":"a2","name":"isGroup","value":"={{ ($json.body?.data?.key?.remoteJid || '').includes('@g.us') }}","type":"boolean"},{"id":"a3","name":"groupId","value":"={{ ($json.body?.data?.key?.remoteJid || '').split('@')[0] }}","type":"string"},{"id":"a4","name":"messageText","value":"={{ $json.body?.data?.message?.conversation || $json.body?.data?.message?.extendedTextMessage?.text || '' }}","type":"string"},{"id":"a5","name":"senderPhone","value":"={{ ($json.body?.data?.participant || $json.body?.data?.key?.remoteJid || '').split('@')[0] }}","type":"string"},{"id":"a6","name":"pushName","value":"={{ $json.body?.data?.pushName || '' }}","type":"string"}]},"options":{}}},{"id":"w2n03","name":"¿Es del grupo Revisión de Casos?","type":"n8n-nodes-base.if","typeVersion":2,"position":[640,400],"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict"},"conditions":[{"id":"c1","leftValue":"={{ $json.groupId }}","rightValue":"={{ ($env['WHATSAPP_GROUP_CASOS'] || 'PENDIENTE').replace('@g.us','') }}","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"options":{}}},{"id":"w2n04","name":"Detener — grupo incorrecto","type":"n8n-nodes-base.noOp","typeVersion":1,"position":[860,260],"parameters":{}},{"id":"w2n05","name":"Parsear respuesta del especialista","type":"n8n-nodes-base.code","typeVersion":2,"position":[860,400],"parameters":{"jsCode":"const text = ($json.messageText || '').trim();\n\nconst patterns = [\n  { regex: /^(\\d{4})\\s+VIABLE:\\s*(.+)$/is,          resultado: 'VIABLE'     },\n  { regex: /^(\\d{4})\\s+FALTA\\s*INFO:\\s*(.+)$/is,    resultado: 'FALTA_INFO' },\n  { regex: /^(\\d{4})\\s+NO\\s*VIABLE[:\\s]*(.*)$/is,   resultado: 'NO_VIABLE'  }\n];\n\nlet sku = null, resultado = null, detalle = '';\nfor (const p of patterns) {\n  const m = text.match(p.regex);\n  if (m) { sku = m[1].padStart(4,'0'); resultado = p.resultado; detalle = (m[2]||'').trim(); break; }\n}\n\nif (!sku || !resultado) {\n  return [{ json: { _skip: true, rawText: text } }];\n}\n\nreturn [{ json: { sku, resultado, detalle, rawText: text, senderPhone: $json.senderPhone, pushName: $json.pushName } }];"}},{"id":"w2n06","name":"¿Mensaje reconocible?","type":"n8n-nodes-base.if","typeVersion":2,"position":[1080,400],"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict"},"conditions":[{"id":"c1","leftValue":"={{ $json._skip }}","rightValue":true,"operator":{"type":"boolean","operation":"notEqual"}}],"combinator":"and"},"options":{}}},{"id":"w2n07","name":"Detener — mensaje no reconocible","type":"n8n-nodes-base.noOp","typeVersion":1,"position":[1300,260],"parameters":{}},{"id":"w2n08","name":"Buscar lead por SKU","type":"n8n-nodes-base.postgres","typeVersion":2.5,"position":[1300,400],"parameters":{"operation":"executeQuery","query":"SELECT id, sku, phone, name, language, estado FROM luxe_smile.leads WHERE sku = $1 AND estado = 'revision_pendiente' LIMIT 1","options":{"queryReplacement":"={{ $json.sku }}"}},"credentials":{"postgres":{"id":"vzzTNppBFKg9XCiK","name":"PostgreSQL — LeadAI"}}},{"id":"w2n09","name":"¿Lead en revisión existe?","type":"n8n-nodes-base.if","typeVersion":2,"position":[1520,400],"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict"},"conditions":[{"id":"c1","leftValue":"={{ $json.id !== undefined && $json.id !== null }}","rightValue":true,"operator":{"type":"boolean","operation":"equal"}}],"combinator":"and"},"options":{}}},{"id":"w2n10","name":"Detener — SKU no válido o estado incorrecto","type":"n8n-nodes-base.noOp","typeVersion":1,"position":[1740,260],"parameters":{}},{"id":"w2n11","name":"Preparar contexto revisión","type":"n8n-nodes-base.set","typeVersion":3.4,"position":[1740,400],"parameters":{"mode":"manual","assignments":{"assignments":[{"id":"a1","name":"leadSku","value":"={{ $json.sku }}","type":"string"},{"id":"a2","name":"leadPhone","value":"={{ $json.phone }}","type":"string"},{"id":"a3","name":"leadName","value":"={{ $json.name || '' }}","type":"string"},{"id":"a4","name":"language","value":"={{ $json.language || 'en' }}","type":"string"},{"id":"a5","name":"resultado","value":"={{ $('Parsear respuesta del especialista').item.json.resultado }}","type":"string"},{"id":"a6","name":"detalle","value":"={{ $('Parsear respuesta del especialista').item.json.detalle }}","type":"string"},{"id":"a7","name":"especialistaNombre","value":"={{ $('Parsear respuesta del especialista').item.json.pushName || 'el especialista' }}","type":"string"}]},"options":{}}},{"id":"w2n12","name":"Router por resultado","type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[1960,400],"parameters":{"mode":"rules","options":{},"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict"},"conditions":[{"id":"r1","leftValue":"={{ $json.resultado }}","rightValue":"VIABLE","operator":{"type":"string","operation":"equals"}}],"combinator":"and"},"outputKey":"viable"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict"},"conditions":[{"id":"r2","leftValue":"={{ $json.resultado }}","rightValue":"FALTA_INFO","operator":{"type":"string","operation":"equa